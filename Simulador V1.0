<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Simulador Interactivo de Rayos X</title>
    <style>
        :root {
            --primary-color: #2c3e50;
            --secondary-color: #3498db;
            --accent-color: #e74c3c;
            --light-color: #ecf0f1;
            --dark-color: #34495e;
            --success-color: #2ecc71;
            --warning-color: #f39c12;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        body {
            background-color: #f5f7fa;
            color: #333;
            line-height: 1.6;
            padding: 20px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
            background: white;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
        }
        
        header {
            background-color: var(--primary-color);
            color: white;
            padding: 20px;
            text-align: center;
            border-radius: 8px;
            margin-bottom: 25px;
        }
        
        h1 {
            font-size: 2.2rem;
            margin-bottom: 10px;
        }
        
        .main-content {
            display: flex;
            flex-wrap: wrap;
            gap: 25px;
        }
        
        .control-panel {
            flex: 1;
            min-width: 320px;
            background-color: #f9f9f9;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            padding: 20px;
            border: 1px solid #ddd;
        }
        
        .image-viewer {
            flex: 2;
            min-width: 400px;
            background-color: #f9f9f9;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            padding: 20px;
            display: flex;
            flex-direction: column;
            border: 1px solid #ddd;
        }
        
        .panel-section {
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 1px solid #eee;
        }
        
        .panel-title {
            font-size: 1.3rem;
            color: var(--primary-color);
            margin-bottom: 15px;
            padding-bottom: 8px;
            border-bottom: 2px solid var(--light-color);
        }
        
        .param-control {
            margin-bottom: 20px;
        }
        
        .param-label {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            font-weight: 500;
        }
        
        .param-value {
            font-weight: bold;
            color: var(--secondary-color);
            background: #f0f8ff;
            padding: 2px 8px;
            border-radius: 4px;
        }
        
        input[type="range"] {
            width: 100%;
            height: 10px;
            -webkit-appearance: none;
            background: linear-gradient(to right, #3498db, #e74c3c);
            border-radius: 5px;
            outline: none;
        }
        
        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: var(--primary-color);
            cursor: pointer;
            box-shadow: 0 0 5px rgba(0,0,0,0.3);
        }
        
        .button-group {
            display: flex;
            gap: 12px;
            margin-top: 20px;
        }
        
        button {
            padding: 14px 20px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s ease;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        
        .btn-prepare {
            background-color: var(--warning-color);
            color: white;
            flex: 1;
        }
        
        .btn-expose {
            background-color: var(--accent-color);
            color: white;
            flex: 1;
        }
        
        .btn-reset {
            background-color: #7f8c8d;
            color: white;
        }
        
        .btn-remove {
            background-color: var(--accent-color);
            color: white;
        }
        
        .btn-prepare.active {
            background-color: var(--success-color);
        }
        
        .btn-expose:disabled {
            background-color: #95a5a6;
            cursor: not-allowed;
        }
        
        .btn-reset:disabled, .btn-remove:disabled {
            background-color: #bdc3c7;
            cursor: not-allowed;
        }
        
        .collimator {
            width: 200px;
            height: 200px;
            border: 3px solid var(--dark-color);
            border-radius: 5px;
            margin: 0 auto;
            position: relative;
            overflow: hidden;
            background-color: #2c3e50;
        }
        
        .collimator-opening {
            position: absolute;
            background-color: var(--secondary-color);
            opacity: 0.7;
            cursor: move;
            border: 2px dashed white;
        }
        
        .image-container {
            flex: 1;
            background-color: #2c3e50;
            border-radius: 5px;
            overflow: hidden;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 400px;
        }
        
        #xray-image {
            max-width: 100%;
            max-height: 100%;
            display: block;
            transition: filter 0.5s ease;
        }
        
        .status-indicators {
            display: flex;
            justify-content: space-around;
            margin-top: 20px;
            padding-top: 15px;
            border-top: 1px solid #eee;
        }
        
        .indicator {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        
        .indicator-light {
            width: 25px;
            height: 25px;
            border-radius: 50%;
            background-color: #bdc3c7;
            margin-bottom: 8px;
            transition: all 0.3s ease;
            box-shadow: 0 0 5px rgba(0,0,0,0.2);
        }
        
        .indicator-light.active {
            background-color: var(--accent-color);
            box-shadow: 0 0 10px var(--accent-color);
        }
        
        .indicator-light.preparation {
            background-color: var(--warning-color);
            box-shadow: 0 0 10px var(--warning-color);
        }
        
        .alert-panel {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(231, 76, 60, 0.85);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            visibility: hidden;
            opacity: 0;
            transition: opacity 0.5s ease;
        }
        
        .alert-panel.visible {
            visibility: visible;
            opacity: 1;
        }
        
        .alert-content {
            background-color: white;
            padding: 40px;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            max-width: 500px;
            width: 90%;
        }
        
        .alert-title {
            font-size: 1.8rem;
            color: var(--accent-color);
            margin-bottom: 15px;
            font-weight: bold;
        }
        
        .upload-section {
            margin-top: 20px;
            text-align: center;
        }
        
        .file-input {
            display: none;
        }
        
        .file-label {
            display: inline-block;
            padding: 12px 20px;
            background-color: var(--secondary-color);
            color: white;
            border-radius: 6px;
            cursor: pointer;
            transition: background-color 0.3s;
            font-weight: 500;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        
        .file-label:hover {
            background-color: #2980b9;
        }
        
        .image-actions {
            display: flex;
            gap: 10px;
            margin-top: 15px;
            justify-content: center;
        }
        
        .empty-state {
            color: #7f8c8d;
            text-align: center;
            padding: 40px 20px;
        }
        
        .empty-state i {
            font-size: 3rem;
            margin-bottom: 15px;
            display: block;
        }
        
        @media (max-width: 768px) {
            .main-content {
                flex-direction: column;
            }
            
            .control-panel, .image-viewer {
                min-width: 100%;
            }
            
            h1 {
                font-size: 1.8rem;
            }
		}

		.default-thumbnail {
    		display: flex;
    		flex-direction: column;
    		align-items: center;
    		cursor: pointer;
    		padding: 8px;
    		border-radius: 6px;
    		border: 2px solid transparent;
    		transition: all 0.3s ease;
		}

		.default-thumbnail:hover {
    		background-color: #e8f4fc;
		}

		.default-thumbnail.selected {
    		border-color: var(--secondary-color);
    		background-color: #e8f4fc;
		}

		.default-thumbnail img {
    		width: 60px;
    		height: 60px;
    		object-fit: cover;
    		border-radius: 4px;
    		margin-bottom: 5px;
    		background-color: #2c3e50;
		}

		.default-thumbnail span {
    		font-size: 0.8rem;
    		text-align: center;
    		color: var(--dark-color);
		}

		.image-gallery {
    		display: grid;
    		grid-template-columns: repeat(3, 1fr);
    		gap: 10px;
    		margin-top: 15px;
    		margin-bottom: 15px;
		}
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>Simulador Interactivo de Rayos X</h1>
            <p>Para entrenamiento y detección de fallas</p>
        </header>
        
        <div class="main-content">
            <div class="control-panel">
                <div class="panel-section">
                    <h2 class="panel-title">Parámetros de Exposición</h2>
                    
                    <div class="param-control">
                        <div class="param-label">
                            <span>Kilovoltaje (kV)</span>
                            <span class="param-value" id="kV-value">70</span>
                        </div>
                        <input type="range" id="kV-slider" min="40" max="120" value="70" step="1">
                        <div class="param-label">
                            <small>Bajo (40-60)</small>
                            <small>Óptimo (70-90)</small>
                            <small>Alto (90-120)</small>
                        </div>
                    </div>
                    
                    <div class="param-control">
                        <div class="param-label">
                            <span>Corriente (mA)</span>
                            <span class="param-value" id="mA-value">200</span>
                        </div>
                        <input type="range" id="mA-slider" min="50" max="500" value="200" step="10">
                    </div>
                    
                    <div class="param-control">
                        <div class="param-label">
                            <span>Tiempo (ms)</span>
                            <span class="param-value" id="time-value">100</span>
                        </div>
                        <input type="range" id="time-slider" min="10" max="1000" value="100" step="10">
                    </div>
                </div>
                
                <div class="panel-section">
    				<h2 class="panel-title">Selección de Imagen</h2>
    
    				<div class="image-gallery" id="default-images-gallery">
        			
    				</div>
    
    				<div class="upload-section">
        				<input type="file" id="file-input" class="file-input" accept="image/*">
        				<label for="file-input" class="file-label">📤 Subir imagen</label>
    				</div>
				</div>
                
                <div class="panel-section">
                    <h2 class="panel-title">Colimación</h2>
                    <div class="collimator">
                        <div class="collimator-opening" id="collimator-opening" style="width: 150px; height: 150px; top: 25px; left: 25px;"></div>
                    </div>
                    <p style="text-align: center; margin-top: 10px; font-size: 0.9rem;">
    Arrastre para mover - Doble clic para redimensionar
</p>
                </div>
                
                <div class="panel-section">
                    <h2 class="panel-title">Controles</h2>
                    <div class="button-group">
                        <button id="prepare-btn" class="btn-prepare">Preparar</button>
                        <button id="expose-btn" class="btn-expose" disabled>Disparo</button>
                    </div>
                    
                    <div class="image-actions">
                        <button id="reset-btn" class="btn-reset" disabled>↻ Borrar cambios</button>
                        <button id="remove-btn" class="btn-remove" disabled>✕ Eliminar imagen</button>
                    </div>
                </div>
                
                <div class="status-indicators">
                    <div class="indicator">
                        <div class="indicator-light" id="prep-indicator"></div>
                        <span>Preparado</span>
                    </div>
                    <div class="indicator">
                        <div class="indicator-light" id="exp-indicator"></div>
                        <span>Exposición</span>
                    </div>
                </div>
            </div>
            
            <div class="image-viewer">
                <h2 class="panel-title">Visualización de Imagen</h2>
                <div class="image-container">
                    <div id="empty-state" class="empty-state">
                        <i>📷</i>
                        <p>Suba una imagen para comenzar</p>
                    </div>
                    <img id="xray-image" style="display:none;" alt="Imagen de rayos X">
                </div>
                <div class="panel-section">
                    <h2 class="panel-title">Diagnóstico de Exposición</h2>
                    <div id="exposure-diagnosis">
                        <p>Esperando imagen y exposición...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="alert-panel" id="exposure-alert">
        <div class="alert-content">
            <h2 class="alert-title">¡EXPOSICIÓN A RADIACIÓN!</h2>
            <p>Simulación en proceso. Manténgase fuera del área.</p>
        </div>
    </div>

    <script>
        // Elementos DOM
        const kVSlider = document.getElementById('kV-slider');
        const kVValue = document.getElementById('kV-value');
        const mASlider = document.getElementById('mA-slider');
        const mAValue = document.getElementById('mA-value');
        const timeSlider = document.getElementById('time-slider');
        const timeValue = document.getElementById('time-value');
        const prepareBtn = document.getElementById('prepare-btn');
        const exposeBtn = document.getElementById('expose-btn');
        const resetBtn = document.getElementById('reset-btn');
        const removeBtn = document.getElementById('remove-btn');
        const prepIndicator = document.getElementById('prep-indicator');
        const expIndicator = document.getElementById('exp-indicator');
        const xrayImage = document.getElementById('xray-image');
        const exposureAlert = document.getElementById('exposure-alert');
        const collimatorOpening = document.getElementById('collimator-opening');
        const exposureDiagnosis = document.getElementById('exposure-diagnosis');
        const fileInput = document.getElementById('file-input');
        const emptyState = document.getElementById('empty-state');
        
        // Estado del simulador
        let isPrepared = false;
        let isExposing = false;
        let originalImage = null;
        let currentImage = null;
		let collimationApplied = false;

		// Ruta base para imágenes predeterminadas
		const baseImagePath = "file:///C:/ImagenesRayosX/";

		// Imágenes predeterminadas disponibles
		const defaultImages = [
    		{ id: 'brazo', name: 'Brazo', filename: 'brazo.png' },
    		{ id: 'pierna', name: 'Pierna', filename: 'pierna.png' },
    		{ id: 'craneo', name: 'Cráneo', filename: 'craneo.png' },
    		{ id: 'dental', name: 'Dental', filename: 'dental.png' },
    		{ id: 'mano', name: 'Mano', filename: 'mano.png' },
    		{ id: 'dedos', name: 'Dedos', filename: 'dedos.png' },
    		{ id: 'torso', name: 'Torso', filename: 'torso.png' }
		];
        
        // Configurar la subida de archivos
        fileInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(event) {
                    // Mostrar imagen y ocultar estado vacío
                    xrayImage.style.display = 'block';
                    emptyState.style.display = 'none';
                    xrayImage.src = event.target.result;
                    originalImage = event.target.result;
                    currentImage = event.target.result;

					// Deseleccionar miniaturas predeterminadas
            		document.querySelectorAll('.default-thumbnail').forEach(thumb => {
                		thumb.classList.remove('selected');
            		});

                    // Habilitar botones
                    resetBtn.disabled = false;
                    removeBtn.disabled = false;
                    
                    exposureDiagnosis.innerHTML = '<p>Imagen cargada. Configure parámetros y presione "Preparar"</p>';
                };
                reader.readAsDataURL(file);
            }
        });

		// Cargar imágenes predeterminadas desde la carpeta local
		function loadDefaultImages() {
    		const gallery = document.getElementById('default-images-gallery');
    
    		defaultImages.forEach(image => {
        		const thumbnail = document.createElement('div');
        		thumbnail.className = 'default-thumbnail';
        		thumbnail.dataset.imageId = image.id;
        
        		thumbnail.innerHTML = `
            		<img src="${baseImagePath}${image.filename}" alt="${image.name}" 
                 onerror="this.src='data:image/svg+xml;base64,'">
            		<span>${image.name}</span>
        		`;
        
        		thumbnail.addEventListener('click', () => {
            		selectDefaultImage(image);
        		});
        
        		gallery.appendChild(thumbnail);
    		});
		}

		// Seleccionar una imagen predeterminada
		function selectDefaultImage(image) {
    		const fullImagePath = `${baseImagePath}${image.filename}`;
    
    		// Mostrar imagen y ocultar estado vacío
    		xrayImage.style.display = 'block';
    		emptyState.style.display = 'none';
    
    		// Intentar cargar la imagen
    		xrayImage.onload = function() {
        		originalImage = fullImagePath;
        		currentImage = fullImagePath;
        
        		// Habilitar botones
        		resetBtn.disabled = false;
        		removeBtn.disabled = false;
        
        		// Deseleccionar todas las miniaturas y seleccionar la actual
        		document.querySelectorAll('.default-thumbnail').forEach(thumb => {
            		thumb.classList.remove('selected');
        		});
        		document.querySelector(`.default-thumbnail[data-image-id="${image.id}"]`).classList.add('selected');
        
        		exposureDiagnosis.innerHTML = `<p>Imagen "${image.name}" cargada. Configure parámetros y presione "Preparar"</p>`;
    		};
    
    		xrayImage.onerror = function() {
        		exposureDiagnosis.innerHTML = `<p style="color: #e74c3c;">Error: No se pudo cargar la imagen ${image.name}. Verifique la ruta: ${baseImagePath}</p>`;
    		};
    
    		xrayImage.src = fullImagePath;
		}

        // Actualizar valores de los parámetros
        kVSlider.addEventListener('input', () => {
            kVValue.textContent = kVSlider.value;
        });
        
        mASlider.addEventListener('input', () => {
            mAValue.textContent = mASlider.value;
        });
        
        timeSlider.addEventListener('input', () => {
            timeValue.textContent = timeSlider.value;
        });
        
        // Botón de preparación
        prepareBtn.addEventListener('click', () => {
            if (!isPrepared) {
                // Simular sonido de preparación
                playSound('prepare');
                
                isPrepared = true;
                prepareBtn.classList.add('active');
                prepIndicator.classList.add('preparation');
                exposeBtn.disabled = false;
                prepareBtn.textContent = 'Cancelar Preparación';
                
                exposureDiagnosis.innerHTML = '<p>Sistema preparado. Listo para exposición.</p>';
            } else {
                isPrepared = false;
                prepareBtn.classList.remove('active');
                prepIndicator.classList.remove('preparation');
                exposeBtn.disabled = true;
                prepareBtn.textContent = 'Preparar';

		playSound('warning');
                
                exposureDiagnosis.innerHTML = '<p>Preparación cancelada.</p>';
            }
        });
        
        // Botón de disparo/exposición
        exposeBtn.addEventListener('click', () => {
            if (isPrepared && !isExposing && currentImage) {
                isExposing = true;
                expIndicator.classList.add('active');
                exposeBtn.disabled = true;
                prepareBtn.disabled = true;
                
                // Mostrar alerta visual
                exposureAlert.classList.add('visible');
                
                // Simular sonido de exposición
                playSound('expose');
                
                // Simular procesamiento de imagen
                simulateExposure();
                
                // Finalizar exposición después del tiempo configurado
                setTimeout(() => {
                    isExposing = false;
                    expIndicator.classList.remove('active');
                    exposeBtn.disabled = false;
                    prepareBtn.disabled = false;
                    
                    // Mantener la alerta visible por 1.5 segundos
                    setTimeout(() => {
                        exposureAlert.classList.remove('visible');
                    }, 1500);
                    
                    // Resetear preparación
                    isPrepared = false;
                    prepareBtn.classList.remove('active');
                    prepIndicator.classList.remove('preparation');
                    prepareBtn.textContent = 'Preparar';
                }, parseInt(timeSlider.value) + 1000);
            }
        });
        
        // Botón para borrar cambios
        resetBtn.addEventListener('click', () => {
            if (currentImage && originalImage) {
                xrayImage.src = originalImage;
                currentImage = originalImage;
                xrayImage.style.filter = 'none';
		collimationApplied = false;
                exposureDiagnosis.innerHTML = '<p>Cambios restablecidos. Imagen original recuperada.</p>';
                
                // Reproducir sonido
                playSound('warning');
            }
        });
        
        // Botón para eliminar imagen
        removeBtn.addEventListener('click', () => {
            xrayImage.style.display = 'none';
            emptyState.style.display = 'block';
            currentImage = null;
            originalImage = null;
	    collimationApplied = false;
            xrayImage.src = '';
            fileInput.value = '';
            
            // Deshabilitar botones
            resetBtn.disabled = true;
            removeBtn.disabled = true;
            exposeBtn.disabled = true;
            prepareBtn.disabled = false;
            
            // Resetear estado
            isPrepared = false;
            prepareBtn.classList.remove('active');
            prepIndicator.classList.remove('preparation');
            expIndicator.classList.remove('active');
            prepareBtn.textContent = 'Preparar';
            
            exposureDiagnosis.innerHTML = '<p>Imagen eliminada. Suba una nueva imagen para comenzar.</p>';
            
        });
        
        // Simular efectos de exposición en la imagen
        function simulateExposure() {
            const kV = parseInt(kVSlider.value);
            const mA = parseInt(mASlider.value);
            const time = parseInt(timeSlider.value);
            
            // Calcular valor de exposición
            const exposureValue = (kV * mA * time) / 10000;
            
            // Simular diferentes condiciones
            let filter = '';
            let diagnosis = '';
            
            if (kV < 60) {
                // Baja penetración - imagen ruidosa y oscura
                filter = `brightness(0.7) contrast(1.2) grayscale(1)`;
                diagnosis = '<p style="color: #e74c3c;">❌ BAJA PENETRACIÓN: Demasiado ruido en la imagen. Aumente el kV para mejorar la penetración.</p>';
            } else if (kV > 100) {
                // Sobreexposición - imagen muy clara
                filter = 'brightness(1.8) contrast(0.9) grayscale(1)';
                diagnosis = '<p style="color: #e74c3c;">❌ SOBREEXPOSICIÓN: Imagen demasiado clara. Disminuya el kV o el tiempo de exposición.</p>';
            } else if (mA < 100 || time < 50) {
                // Subexposición - imagen oscura
                filter = 'brightness(0.6) contrast(1.1) grayscale(1)';
                diagnosis = '<p style="color: #e74c3c;">❌ SUBEXPOSICIÓN: Imagen demasiado oscura. Aumente mA o tiempo de exposición.</p>';
            } else {
                // Exposición adecuada
                filter = 'brightness(1.1) contrast(1.1) grayscale(1)';
                diagnosis = '<p style="color: #2ecc71;">✅ EXPOSICIÓN ADECUADA: Buena calidad de imagen con contraste y detalle apropiados.</p>';
            }
            
            xrayImage.style.filter = filter;
            
            // Mostrar diagnóstico
            exposureDiagnosis.innerHTML = diagnosis;
            
            // Aplicar colimación
            setTimeout(() => {
    		if (currentImage) {
        			applyCollimation();
   			 }
		}, 100);
        }
        
        // Aplicar efecto de colimación
        function applyCollimation() {
            	    if (!currentImage || !originalImage) return;
    
    // Restaurar la imagen original antes de aplicar la colimación
    const img = new Image();
    img.onload = function() {
        // Crear un canvas para procesar la imagen
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        
        // Establecer dimensiones del canvas
        canvas.width = img.width;
        canvas.height = img.height;
        
        // Dibujar la imagen original en el canvas
        ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
        
        // Obtener los datos de la imagen
        const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        const data = imageData.data;
        
        // Calcular posición y tamaño del área de colimación
        const collimatorRect = collimatorOpening.getBoundingClientRect();
        const imageRect = xrayImage.getBoundingClientRect();
        
        // Si la imagen no está visible, usar valores por defecto
        if (imageRect.width === 0 || imageRect.height === 0) {
            return;
        }
        
        const scaleX = canvas.width / imageRect.width;
        const scaleY = canvas.height / imageRect.height;
        
        const centerX = (collimatorRect.left - imageRect.left + collimatorRect.width / 2) * scaleX;
        const centerY = (collimatorRect.top - imageRect.top + collimatorRect.height / 2) * scaleY;
        const radiusX = (collimatorRect.width / 2) * scaleX;
        const radiusY = (collimatorRect.height / 2) * scaleY;
        
        // Aplicar efecto de colimación (oscurecer áreas fuera de la elipse)
        for (let y = 0; y < canvas.height; y++) {
            for (let x = 0; x < canvas.width; x++) {
                // Calcular posición en el array de datos
                const index = (y * canvas.width + x) * 4;
                
                // Verificar si el píxel está fuera del área de colimación
                const dx = (x - centerX) / radiusX;
                const dy = (y - centerY) / radiusY;
                const distance = dx * dx + dy * dy;
                
                if (distance > 1) {
                    // Oscurecer píxeles fuera del área de colimación (60% de opacidad)
                    data[index] = Math.max(0, data[index] * 0.4);     // Red
                    data[index + 1] = Math.max(0, data[index + 1] * 0.4); // Green
                    data[index + 2] = Math.max(0, data[index + 2] * 0.4); // Blue
                }
            }
        }
        
        // Poner los datos procesados de vuelta en el canvas
        ctx.putImageData(imageData, 0, 0);
        
        // Actualizar la imagen con el efecto de colimación aplicado
        xrayImage.src = canvas.toDataURL();
    };
    img.src = originalImage;
        }
        
        // Reproducir sonidos
        function playSound(type) {
            try {
                // Crear contextos de audio según el tipo
                const audioContext = new (window.AudioContext || window.webkitAudioContext)();
                const oscillator = audioContext.createOscillator();
                const gainNode = audioContext.createGain();
                
                oscillator.connect(gainNode);
                gainNode.connect(audioContext.destination);
                
                if (type === 'prepare') {
                    // Sonido de preparación (tono ascendente)
                    oscillator.type = 'sine';
                    oscillator.frequency.setValueAtTime(330, audioContext.currentTime);
                    oscillator.frequency.exponentialRampToValueAtTime(660, audioContext.currentTime + 0.5);
                    gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);
                    gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.5);
                    oscillator.start();
                    oscillator.stop(audioContext.currentTime + 0.5);
                } else if (type === 'expose') {
                    // Sonido de exposición (tono constante)
                    oscillator.type = 'sawtooth';
                    oscillator.frequency.setValueAtTime(220, audioContext.currentTime);
                    gainNode.gain.setValueAtTime(0.2, audioContext.currentTime);
                    gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 1.5);
                    oscillator.start();
                    oscillator.stop(audioContext.currentTime + 1.5);
                } else if (type === 'warning') {
                    // Sonido de advertencia (dos tonos cortos)
                    oscillator.type = 'square';
                    oscillator.frequency.setValueAtTime(440, audioContext.currentTime);
                    gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);
                    gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.1);
                    oscillator.start();
                    oscillator.stop(audioContext.currentTime + 0.1);
                    
                    setTimeout(() => {
                        const oscillator2 = audioContext.createOscillator();
                        const gainNode2 = audioContext.createGain();
                        oscillator2.connect(gainNode2);
                        gainNode2.connect(audioContext.destination);
                        
                        oscillator2.type = 'square';
                        oscillator2.frequency.setValueAtTime(440, audioContext.currentTime);
                        gainNode2.gain.setValueAtTime(0.3, audioContext.currentTime);
                        gainNode2.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.1);
                        oscillator2.start();
                        oscillator2.stop(audioContext.currentTime + 0.1);
                    }, 150);
                }
            } catch (error) {
                console.log("Error reproduciendo sonido:", error);
            }
        }
        
                // Configurar el colimador como interactivo
function setupCollimator() {
    let isDragging = false;
    let startX, startY, startLeft, startTop;
    
    collimatorOpening.addEventListener('mousedown', (e) => {
        isDragging = true;
        startX = e.clientX;
        startY = e.clientY;
        startLeft = parseInt(window.getComputedStyle(collimatorOpening).left);
        startTop = parseInt(window.getComputedStyle(collimatorOpening).top);
        e.preventDefault();
    });
    
    document.addEventListener('mousemove', (e) => {
        if (isDragging) {
            const dx = e.clientX - startX;
            const dy = e.clientY - startY;
            
            // Limitar el movimiento dentro del colimador
            const maxX = 200 - parseInt(window.getComputedStyle(collimatorOpening).width);
            const maxY = 200 - parseInt(window.getComputedStyle(collimatorOpening).height);
            
            const newLeft = Math.max(0, Math.min(maxX, startLeft + dx));
            const newTop = Math.max(0, Math.min(maxY, startTop + dy));
            
            collimatorOpening.style.left = `${newLeft}px`;
            collimatorOpening.style.top = `${newTop}px`;
        }
    });
    
    document.addEventListener('mouseup', () => {
        isDragging = false;
    });
    
    // Hacer el colimador redimensionable
    let isResizing = false;
    let startWidth, startHeight;
    
    collimatorOpening.addEventListener('dblclick', (e) => {
        isResizing = true;
        startX = e.clientX;
        startY = e.clientY;
        startWidth = parseInt(window.getComputedStyle(collimatorOpening).width);
        startHeight = parseInt(window.getComputedStyle(collimatorOpening).height);
        e.preventDefault();
    });
    
    document.addEventListener('mousemove', (e) => {
        if (isResizing) {
            const dx = e.clientX - startX;
            const dy = e.clientY - startY;
            
            // Limitar el tamaño mínimo y máximo
            const newWidth = Math.max(50, Math.min(190, startWidth + dx));
            const newHeight = Math.max(50, Math.min(190, startHeight + dy));
            
            collimatorOpening.style.width = `${newWidth}px`;
            collimatorOpening.style.height = `${newHeight}px`;
            
            // Ajustar posición para mantener el centro
            const leftChange = (startWidth - newWidth) / 2;
            const topChange = (startHeight - newHeight) / 2;
            
            const currentLeft = parseInt(window.getComputedStyle(collimatorOpening).left);
            const currentTop = parseInt(window.getComputedStyle(collimatorOpening).top);
            
            collimatorOpening.style.left = `${Math.max(0, Math.min(200 - newWidth, currentLeft + leftChange))}px`;
            collimatorOpening.style.top = `${Math.max(0, Math.min(200 - newHeight, currentTop + topChange))}px`;
        }
    });
    
    document.addEventListener('mouseup', () => {
        isResizing = false;
    });
}
       
	// Inicializar el colimador después de cargar la página
window.addEventListener('load', () => {
    setupCollimator();
	loadDefaultImages();
});

    </script>
</body>
</html>
